# ========================================================================
# LOCAL DEVELOPMENT (docker compose up postgres redis)
# ========================================================================
NODE_ENV=development
PORT=8000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/luizianne
REDIS_URL=redis://localhost:6379

# ========================================================================
# PRODUCTION (free tier stack)
# ------------------------------------------------------------------------
# Supabase   → DATABASE_URL  (Settings → Database → Connection string → URI)
#   Use the "Session pooler" URL (port 5432) for NestJS:
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
#
# Upstash    → REDIS_URL     (Database → Connect → ioredis)
#   rediss://default:<token>@<endpoint>.upstash.io:6379
#
# Render     → API host       (deploy via render.yaml)
# Vercel     → Web host       (Root Directory: apps/web)
# ========================================================================

# Pool sizing (Supabase free tier: keep small)
PG_POOL_MIN=1
PG_POOL_MAX=5
# FIX #10: Set to 'false' only if your provider has self-signed certs
# PG_SSL_REJECT_UNAUTHORIZED=true
# REDIS_TLS_REJECT_UNAUTHORIZED=true

# Câmara dos Deputados API
CAMARA_API_BASE_URL=https://dadosabertos.camara.leg.br/api/v2
TARGET_DEPUTY_EXTERNAL_ID=178866
INGESTION_CRON=0 */6 * * *
INGESTION_CONCURRENCY=2
# FIX #20: Minimum delay (ms) between API requests to avoid rate limiting
CAMARA_API_MIN_DELAY_MS=200

# PNCP — Portal Nacional de Contratacoes Publicas (editais federais)
PNCP_API_BASE_URL=https://pncp.gov.br/api/consulta
EDITAIS_CRON=0 */6 * * *
EDITAIS_ALERT_CRON=0 8 * * *

# E-mail (Resend — resend.com, gratuito até 3k/mês)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@luizianne-leis.vercel.app

# Cache & throttling
CACHE_TTL_SECONDS=600
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# FIX #4: Máximo de conexões SSE simultâneas
SSE_MAX_CONNECTIONS=100

# CORS — comma-separated list of allowed origins
# FIX #25: NÃO use '*' em produção
CORS_ORIGINS=https://luizianne.vercel.app,http://localhost:3000

# Swagger UI in prod (set to 'true' to expose /docs in production)
# FIX #12: Desabilitado por padrão em produção
SWAGGER_ENABLED=false

# Rastreador de ausências em votações nominais (cron diário)
ABSENCE_CRON=0 6 * * *

# Alerta de leis aprovadas (cron semanal — segunda às 9h)
LAWS_ALERT_CRON=0 9 * * 1

# Portal da Transparência — emendas orçamentárias
# Chave gratuita: https://portaldatransparencia.gov.br/api
TRANSPARENCIA_API_KEY=sua-chave-aqui
DEPUTY_TRANSPARENCIA_NAME=LUIZIANNE LINS
DEPUTY_TRANSPARENCIA_CODE=
EMENDAS_ORC_CRON=0 3 * * 5

# FIX #12 (ALTO): ADMIN_TOKEN DEVE ser gerado com: openssl rand -hex 32
# NUNCA use o valor padrão em produção!
ADMIN_TOKEN=GERE_UM_TOKEN_SEGURO_COM_openssl_rand_hex_32

# Supabase JWT Secret — necessário para validação JWT no backend
# Encontre em: Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase Auth — Vercel: adicione todas as variáveis abaixo
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<legacy-anon-jwt>
SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt>
NEXT_PUBLIC_APP_URL=https://luizianne-leis.vercel.app
ADMIN_EMAIL=seu@email.com
