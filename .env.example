# ========= Backend =========
NODE_ENV=development
PORT=8000

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/luizianne
PG_POOL_MIN=2
PG_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379

# Câmara dos Deputados API
CAMARA_API_BASE_URL=https://dadosabertos.camara.leg.br/api/v2
# ID externo da deputada principal monitorada (Luizianne Lins). Ajuste se necessário.
TARGET_DEPUTY_EXTERNAL_ID=141401
INGESTION_CRON=*/15 * * * *
INGESTION_CONCURRENCY=4

# Cache
CACHE_TTL_SECONDS=300
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
