# ========================================================================
# LOCAL DEVELOPMENT (docker compose up postgres redis)
# ========================================================================
NODE_ENV=development
PORT=8000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/luizianne
REDIS_URL=redis://localhost:6379

# ========================================================================
# PRODUCTION (free tier stack)
# ------------------------------------------------------------------------
# Supabase   → DATABASE_URL  (Settings → Database → Connection string → URI)
#   Use the "Session pooler" URL (port 5432) for NestJS:
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
#
# Upstash    → REDIS_URL     (Database → Connect → ioredis)
#   rediss://default:<token>@<endpoint>.upstash.io:6379
#
# Render     → API host       (deploy via render.yaml)
# Vercel     → Web host       (Root Directory: apps/web)
# ========================================================================

# Pool sizing (Supabase free tier: keep small)
PG_POOL_MIN=1
PG_POOL_MAX=5

# Câmara dos Deputados API
CAMARA_API_BASE_URL=https://dadosabertos.camara.leg.br/api/v2
TARGET_DEPUTY_EXTERNAL_ID=178866
INGESTION_CRON=0 */6 * * *
INGESTION_CONCURRENCY=2

# PNCP — Portal Nacional de Contratacoes Publicas (editais federais)
PNCP_API_BASE_URL=https://pncp.gov.br/api/consulta
EDITAIS_CRON=0 */6 * * *
EDITAIS_ALERT_CRON=0 8 * * *

# E-mail (Resend — resend.com, gratuito até 3k/mês)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@luizianne-leis.vercel.app

# Cache & throttling
CACHE_TTL_SECONDS=600
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# CORS — comma-separated list of allowed origins (or '*' for any)
CORS_ORIGINS=https://luizianne.vercel.app,http://localhost:3000

# Swagger UI in prod (set to 'true' to expose /docs in production)
SWAGGER_ENABLED=true

# Admin (trigger manual)
ADMIN_TOKEN=change-me

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase Auth — Vercel: adicione todas as variáveis abaixo
# Encontre em: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<legacy-anon-jwt>
# Supabase Dashboard → Project Settings → API → Secret keys (Legacy service_role)
SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt>
# URL pública do Vercel (sem trailing slash)
NEXT_PUBLIC_APP_URL=https://luizianne-leis.vercel.app
# E-mail do admin principal (garante role=admin no primeiro login)
ADMIN_EMAIL=seu@email.com
