{
  "name": "@luizianne/api",
  "version": "0.1.0",
  "private": true,
  "description": "Backend modular monolith — Core API, Ingestion, Analytics, Notifications",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
